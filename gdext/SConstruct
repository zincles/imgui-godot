#!/usr/bin/env python
# ── Required system libraries ─────────────────────────────────────────────
#   freetype2   Arch: freetype2          Debian/Ubuntu: libfreetype-dev
#   libpng      Arch: libpng             Debian/Ubuntu: libpng-dev
#   zlib        Arch: zlib               Debian/Ubuntu: zlib1g-dev
#   bzip2       Arch: bzip2              Debian/Ubuntu: libbz2-dev
#   brotli      Arch: brotli             Debian/Ubuntu: libbrotli-dev
# ──────────────────────────────────────────────────────────────────────────
from glob import glob
from pathlib import Path
import os
import shutil
import subprocess
import SCons
import sys
class CustomCacheDir(SCons.CacheDir.CacheDir):
    @classmethod
    def copy_to_cache(cls, env, src, dst) -> str:
        fn = str(src)
        if fn.startswith("godot-cpp"):
            if os.path.splitext(fn)[1] not in [".lib", ".dll", ".exp", ".a", ".so"]:
                return super().copy_to_cache(env, src, dst)
        return None


env = SConscript("godot-cpp/SConstruct")
env.CacheDir("scons_cache", CustomCacheDir)
env.Append(CPPDEFINES=['IMGUI_USER_CONFIG="\\"imconfig-godot.h\\""', "IGN_EXPORT"])
env.Append(CPPPATH=["src/", "imgui/", "include/", "gen/"])
env.Replace(CXXFLAGS=str(env["CXXFLAGS"]).replace("c++17", "c++20"))

windows = env["platform"] == "windows"
linux = env["platform"] == "linux"
config = "release" if env["target"] == "template_release" else "debug"

if config == "release":
    if windows:
        env.Append(CPPDEFINES=["NDEBUG"])

# -- system library detection (replaces vcpkg) --
ext_libpath = []
ext_libs = []
ext_cpppath = []

def parse_pkgconfig(pkg, libpath, cpppath, libs):
    """Run pkg-config and extract -I/-L/-l flags into the given lists."""
    try:
        r = subprocess.run(
            ["pkg-config", "--cflags", "--libs", pkg],
            capture_output=True, text=True, check=True
        )
        for flag in r.stdout.strip().split():
            if flag.startswith("-I"):   cpppath.append(flag[2:])
            elif flag.startswith("-L"): libpath.append(flag[2:])
            elif flag.startswith("-l"): libs.append(flag[2:])
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False

def check_header(path):
    return os.path.isfile(path) and os.access(path, os.R_OK)

if windows:
    if env["arch"] == "arm64":
        triplet = "arm64-windows-static"
    else:
        triplet = "x64-windows-static"
    vcpkg_root = os.environ.get("VCPKG_ROOT", "")
    if vcpkg_root and not os.path.exists(f"vcpkg_installed/{triplet}"):
        subprocess.call(f'"{vcpkg_root}/vcpkg" install --triplet {triplet}', shell=True)
    ext_cpppath.append(f"vcpkg_installed/{triplet}/include")
    ext_libpath.append(f"vcpkg_installed/{triplet}/lib")
    ext_libs += ["freetype", "bz2", "libpng16", "zlib", "brotlidec", "brotlicommon"]

elif env["platform"] == "macos":
    if not parse_pkgconfig("freetype2", ext_libpath, ext_cpppath, ext_libs):
        # fallback: homebrew
        brew = subprocess.run(["brew", "--prefix"], capture_output=True, text=True)
        if brew.returncode == 0 and brew.stdout.strip():
            p = brew.stdout.strip()
            ext_cpppath += [f"{p}/include", f"{p}/include/freetype2"]
            ext_libpath.append(f"{p}/lib")
        else:
            print("ERROR: freetype2 not found. Install: brew install freetype")
            sys.exit(1)
    ext_libs += ["bz2", "png16", "z", "brotlidec", "brotlicommon"]

else:
    # Linux / BSD
    if not parse_pkgconfig("freetype2", ext_libpath, ext_cpppath, ext_libs):
        for inc in ["/usr/include/freetype2", "/usr/local/include/freetype2"]:
            if check_header(f"{inc}/ft2build.h"):
                ext_cpppath.append(inc)
                ext_libs.append("freetype")
                break
        else:
            print("ERROR: freetype2 dev files not found! Install: libfreetype-dev / freetype-devel")
            sys.exit(1)
    ext_libs += ["bz2", "png16", "z", "brotlidec", "brotlicommon"]

env.Append(CPPPATH=ext_cpppath)
# -- end system library detection --

if not os.path.exists("gen/imgui_bindings.gen.h"):
    subprocess.call("python scripts/gds_bindings.py", shell=True)

shutil.copy("imgui-godot-native.gdextension", "../addons/imgui-godot/")
shutil.copytree("include", "../addons/imgui-godot/include", dirs_exist_ok=True)

sources = Glob("src/*.cpp") + Glob("imgui/*.cpp") + Glob("gen/*.cpp")

(extension_path,) = glob("../addons/imgui-godot/*.gdextension")
addon_path = Path(extension_path).parent
project_name = Path(extension_path).stem

libpath = env.get("LIBPATH", [])
libs = [env["LIBS"]]

env.Append(CPPPATH=["imgui/misc/freetype/"])
env.Append(CPPDEFINES=["IMGUI_ENABLE_FREETYPE"])
# env.Append(CPPDEFINES=["IMGUI_ENABLE_FREETYPE_LUNASVG"])
sources += Glob("imgui/misc/freetype/*.cpp")
libpath += ext_libpath
libs += ext_libs

if env["platform"] == "macos":
    library = env.SharedLibrary(
        "{0}/bin/lib{1}.{2}.{3}.framework/{1}.{2}.{3}".format(
            addon_path,
            project_name,
            env["platform"],
            config,
        ),
        source=sources,
        LIBPATH=libpath,
        LIBS=libs,
    )
else:
    library = env.SharedLibrary(
        "{}/bin/lib{}.{}.{}.{}{}".format(
            addon_path,
            project_name,
            env["platform"],
            config,
            env["arch"],
            env["SHLIBSUFFIX"],
        ),
        source=sources,
        LIBPATH=libpath,
        LIBS=libs,
    )

Default(library)
